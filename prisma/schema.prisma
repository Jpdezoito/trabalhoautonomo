enum ClientAvailabilityStatus {
  AT_HOME
  AWAY_RETURNING
  AWAY_UNAVAILABLE
  NOT_INFORMED
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  WORKER
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  ACTIVE
  PENDING
  SUSPENDED
  BANNED
  DELETED
}

enum WorkerApprovalStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  ARCHIVED
}

enum ProfessionalPlan {
  FREE
  PRO
  DESTAQUE
}

enum VerificationStatus {
  NOT_REQUESTED
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum FacialEnrollmentStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum FacialCaptureSource {
  WEBCAM
  UPLOAD
}

enum TrustVerificationStatus {
  NOT_VERIFIED
  PENDING
  IN_REVIEW
  VERIFIED
  REJECTED
  NEEDS_REVIEW
}

enum TrustVerificationType {
  FACE
  DOCUMENT
  ADDRESS
  PHONE
  ACTIVITY
  PORTFOLIO
  EXPERIENCE
  CERTIFICATION
  BACKGROUND_CHECK
  ADMIN_REVIEW
}

enum WorkerEvidenceType {
  IDENTITY_DOCUMENT
  ADDRESS_PROOF
  ACTIVITY_PROOF
  PORTFOLIO_PROOF
  WORKER_ON_SITE
  WORKSHOP_EVIDENCE
  VEHICLE_EVIDENCE
  CERTIFICATE
  LICENSE
}

enum WorkerEvidenceStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum WorkerQualificationType {
  EDUCATION
  COURSE
  CERTIFICATION
  LICENSE
}

enum ConsentRecordType {
  TRUST_IDENTITY
  FACIAL_VERIFICATION
  DOCUMENT_VERIFICATION
  BACKGROUND_CHECK
}

enum PasswordRecoveryMethod {
  EMAIL_FACE
  PHONE_FACE
}

enum PasswordRecoveryStatus {
  PENDING_CONTACT
  CONTACT_VERIFIED
  FACE_VERIFIED
  COMPLETED
  EXPIRED
  BLOCKED
  FAILED
  UNAVAILABLE
}

enum PasswordRecoveryStage {
  START
  CONTACT
  FACE
  PASSWORD
  DONE
}

enum QuoteStatus {
  OPEN
  IN_REVIEW
  QUOTED
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
  COMPLETED
}

enum QuotePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
  REJECTED
  FLAGGED
}

enum ContactChannel {
  PLATFORM
  WHATSAPP
  PHONE
  EMAIL
}

enum ContactRequestStatus {
  NEW
  VIEWED
  CONTACTED
  CONVERTED
  DISMISSED
}

enum ModerationTargetType {
  USER
  WORKER_PROFILE
  PORTFOLIO_IMAGE
  REVIEW
  QUOTE_REQUEST
  CONTACT_REQUEST
}

enum ModerationStatus {
  OPEN
  IN_REVIEW
  ACTION_REQUIRED
  RESOLVED
  DISMISSED
}

enum ModerationReason {
  SPAM
  FRAUD
  OFFENSIVE_CONTENT
  FAKE_PROFILE
  SAFETY_RISK
  PAYMENT_DISPUTE
  LOW_QUALITY
  OTHER
}

enum NotificationType {
  QUOTE_CREATED
  QUOTE_UPDATED
  REVIEW_CREATED
  PROFILE_APPROVED
  PROFILE_REJECTED
  VERIFICATION_UPDATED
  MODERATION_UPDATED
  SYSTEM
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

model User {
  id                       String                     @id @default(cuid())
  name                     String
  email                    String                     @unique
  emailVerified            DateTime?
  passwordHash             String?
  image                    String?
  phone                    String?
  role                     UserRole                   @default(CLIENT)
  status                   AccountStatus              @default(PENDING)
  lastLoginAt              DateTime?
  facialRecoveryEnabled    Boolean                    @default(false)
  facialRecoveryEnabledAt  DateTime?
  deletedAt                DateTime?
  accounts                 Account[]
  sessions                 Session[]
  clientProfile            ClientProfile?
  workerProfile            WorkerProfile?
  adminProfile             AdminProfile?
  facialEnrollments        FacialEnrollment[]
  consentRecords           ConsentRecord[]
  passwordRecoverySessions PasswordRecoverySession[]
  trustVerifications       TrustVerificationRequest[]
  sentMessages             QuoteMessage[]             @relation("QuoteMessageSender")
  adminLogs                AdminLog[]                 @relation("AdminLogActor")
  notifications            Notification[]
  reportsMade              ModerationReport[]         @relation("ModerationReporter")
  reportsAssigned          ModerationReport[]         @relation("ModerationAssignee")
  reportsTargetingUser     ModerationReport[]         @relation("ModerationTargetUser")
  facialReviews            FacialEnrollment[]         @relation("FacialEnrollmentReviewer")
  trustReviews             TrustVerificationRequest[] @relation("TrustVerificationReviewer")
  reviewsModerated         Review[]                   @relation("ReviewModerator")
  settingsUpdated          PlatformSetting[]          @relation("SettingUpdatedBy")
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  @@index([role, status])
  @@index([facialRecoveryEnabled])
  @@index([deletedAt])
}

model FacialEnrollment {
  id                        String                 @id @default(cuid())
  userId                    String
  user                      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedById              String?
  reviewedBy                User?                  @relation("FacialEnrollmentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  status                    FacialEnrollmentStatus @default(PENDING)
  captureSource             FacialCaptureSource
  provider                  String                 @default("internal-v1")
  storageKey                String
  metadata                  Json?
  consentAcceptedAt         DateTime
  submittedAt               DateTime               @default(now())
  reviewedAt                DateTime?
  approvedAt                DateTime?
  rejectedAt                DateTime?
  retryCount                Int                    @default(0)
  usableForPasswordRecovery Boolean                @default(false)
  reviewNotes               String?                @db.Text
  deletedAt                 DateTime?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  @@index([userId, status, createdAt])
  @@index([reviewedById, status])
  @@index([usableForPasswordRecovery])
  @@index([deletedAt])
}

model ConsentRecord {
  id                String                     @id @default(cuid())
  userId            String
  user              User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              ConsentRecordType
  title             String
  acceptedAt        DateTime
  revokedAt         DateTime?
  ipAddress         String?
  userAgent         String?
  metadata          Json?
  trustVerification TrustVerificationRequest[]
  workerEvidences   WorkerEvidence[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([userId, type, acceptedAt])
}

model TrustVerificationRequest {
  id                 String                  @id @default(cuid())
  userId             String
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workerProfileId    String?
  workerProfile      WorkerProfile?          @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  clientProfileId    String?
  clientProfile      ClientProfile?          @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  consentRecordId    String?
  consentRecord      ConsentRecord?          @relation(fields: [consentRecordId], references: [id], onDelete: SetNull)
  type               TrustVerificationType
  status             TrustVerificationStatus @default(PENDING)
  provider           String?
  providerReference  String?
  providerMetadata   Json?
  documentType       String?
  documentReference  String?
  documentStorageKey String?
  submittedAt        DateTime                @default(now())
  reviewedById       String?
  reviewedBy         User?                   @relation("TrustVerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt         DateTime?
  verifiedAt         DateTime?
  rejectedAt         DateTime?
  retryCount         Int                     @default(0)
  reviewNotes        String?                 @db.Text
  deletedAt          DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([userId, type, status])
  @@index([workerProfileId, status])
  @@index([clientProfileId, status])
  @@index([reviewedById, status])
  @@index([deletedAt])
}

model PasswordRecoverySession {
  id                   String                       @id @default(cuid())
  publicToken          String                       @unique
  userId               String?
  user                 User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  method               PasswordRecoveryMethod
  status               PasswordRecoveryStatus       @default(PENDING_CONTACT)
  currentStage         PasswordRecoveryStage        @default(CONTACT)
  contactHash          String
  contactMasked        String
  challengeCodeHash    String?
  challengeExpiresAt   DateTime?
  challengeSentAt      DateTime?
  contactVerifiedAt    DateTime?
  faceVerifiedAt       DateTime?
  resetAllowedUntil    DateTime?
  completedAt          DateTime?
  contactAttemptCount  Int                          @default(0)
  faceAttemptCount     Int                          @default(0)
  passwordAttemptCount Int                          @default(0)
  lastAttemptAt        DateTime?
  unavailableReason    String?
  metadata             Json?
  expiresAt            DateTime
  attemptLogs          PasswordRecoveryAttemptLog[]
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  @@index([publicToken])
  @@index([userId, createdAt])
  @@index([status, expiresAt])
}

model PasswordRecoveryAttemptLog {
  id        String                   @id @default(cuid())
  sessionId String?
  session   PasswordRecoverySession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stage     PasswordRecoveryStage
  success   Boolean                  @default(false)
  reason    String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime                 @default(now())

  @@index([sessionId, createdAt])
  @@index([stage, createdAt])
}

model ClientProfile {
  id                      String                     @id @default(cuid())
  userId                  String                     @unique
  user                    User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cityId                  String?
  city                    City?                      @relation(fields: [cityId], references: [id], onDelete: SetNull)
  neighborhoodId          String?
  neighborhood            Neighborhood?              @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  addressNote             String?
  document                String?
  trustVerificationStatus TrustVerificationStatus    @default(NOT_VERIFIED)
  publicTrustBadgeEnabled Boolean                    @default(false)
  quoteRequests           QuoteRequest[]
  reviews                 Review[]
  favorites               Favorite[]
  contactRequests         ContactRequest[]
  leads                   Lead[]
  trustVerifications      TrustVerificationRequest[]
  deletedAt               DateTime?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt

  @@index([cityId, neighborhoodId])
  @@index([trustVerificationStatus, publicTrustBadgeEnabled])
  @@index([deletedAt])
}

model WorkerProfile {
  id                      String                     @id @default(cuid())
  userId                  String                     @unique
  user                    User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug                    String                     @unique
  publicName              String
  headline                String
  bio                     String                     @db.Text
  document                String?
  companyName             String?
  cityId                  String?
  city                    City?                      @relation(fields: [cityId], references: [id], onDelete: SetNull)
  neighborhoodId          String?
  neighborhood            Neighborhood?              @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  serviceRadiusKm         Int                        @default(15)
  yearsExperience         Int                        @default(0)
  experienceSummary       String?                    @db.Text
  basePriceDescription    String?
  whatsapp                String?
  websiteUrl              String?
  meiNumber               String?
  companyDocument         String?
  licenseRegistration     String?
  educationLevel          String?
  collegeName             String?
  termsAcceptedAt         DateTime?
  verificationConsentAt   DateTime?
  phoneVerifiedAt         DateTime?
  identityDocumentStatus  VerificationStatus         @default(NOT_REQUESTED)
  addressProofStatus      VerificationStatus         @default(NOT_REQUESTED)
  activityProofStatus     VerificationStatus         @default(NOT_REQUESTED)
  portfolioProofStatus    VerificationStatus         @default(NOT_REQUESTED)
  minimumPortfolioMet     Boolean                    @default(false)
  isAvailable             Boolean                    @default(true)
  plan                    ProfessionalPlan           @default(FREE)
  planStartedAt           DateTime?
  planExpiresAt           DateTime?
  ultimaAtividade         DateTime                   @default(now())
  approvalStatus          WorkerApprovalStatus       @default(DRAFT)
  verificationStatus      VerificationStatus         @default(NOT_REQUESTED)
  trustVerificationStatus TrustVerificationStatus    @default(NOT_VERIFIED)
  publicTrustBadgeEnabled Boolean                    @default(false)
  approvedAt              DateTime?
  approvedById            String?
  rejectionReason         String?
  averageRating           Decimal                    @default(0) @db.Decimal(3, 2)
  reviewsCount            Int                        @default(0)
  jobsCompleted           Int                        @default(0)
  services                WorkerService[]
  serviceAreas            WorkerServiceArea[]
  portfolioImages         PortfolioImage[]
  evidences               WorkerEvidence[]
  qualifications          WorkerQualification[]
  quoteRequests           QuoteRequest[]
  reviews                 Review[]
  favorites               Favorite[]
  contactRequests         ContactRequest[]
  leads                   Lead[]
  verificationRequests    VerificationRequest[]
  trustVerifications      TrustVerificationRequest[]
  moderationReports       ModerationReport[]
  deletedAt               DateTime?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt

  @@index([approvalStatus, verificationStatus])
  @@index([trustVerificationStatus, publicTrustBadgeEnabled])
  @@index([identityDocumentStatus, addressProofStatus, activityProofStatus, portfolioProofStatus])
  @@index([cityId, neighborhoodId])
  @@index([plan, planExpiresAt])
  @@index([isAvailable, ultimaAtividade])
  @@index([isAvailable, averageRating])
  @@index([deletedAt])
}

model AdminProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          String     @id @default(cuid())
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  name        String
  slug        String     @unique
  description String     @db.Text
  group       String?
  icon        String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  services    Service[]
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([isActive, sortOrder])
  @@index([parentId, isActive])
  @@index([group])
  @@index([deletedAt])
}

model Service {
  id              String           @id @default(cuid())
  categoryId      String
  category        Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name            String
  slug            String           @unique
  description     String?          @db.Text
  sortOrder       Int              @default(0)
  isActive        Boolean          @default(true)
  workers         WorkerService[]
  quoteRequests   QuoteRequest[]
  contactRequests ContactRequest[]
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([categoryId, isActive])
  @@index([deletedAt])
}

model WorkerService {
  workerProfileId String
  serviceId       String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  service         Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  priceFrom       Decimal?      @db.Decimal(10, 2)
  isPrimary       Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@id([workerProfileId, serviceId])
  @@index([serviceId])
}

model City {
  id              String              @id @default(cuid())
  name            String
  state           String
  stateCode       String
  slug            String              @unique
  isActive        Boolean             @default(true)
  neighborhoods   Neighborhood[]
  clients         ClientProfile[]
  workers         WorkerProfile[]
  quoteRequests   QuoteRequest[]
  contactRequests ContactRequest[]
  serviceAreas    WorkerServiceArea[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([stateCode, isActive])
}

model Neighborhood {
  id              String              @id @default(cuid())
  cityId          String
  city            City                @relation(fields: [cityId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  isActive        Boolean             @default(true)
  clients         ClientProfile[]
  workers         WorkerProfile[]
  quoteRequests   QuoteRequest[]
  contactRequests ContactRequest[]
  serviceAreas    WorkerServiceArea[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([cityId, slug])
  @@index([cityId, isActive])
}

model WorkerServiceArea {
  id              String        @id @default(cuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  cityId          String
  city            City          @relation(fields: [cityId], references: [id], onDelete: Restrict)
  neighborhoodId  String?
  neighborhood    Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: Restrict)
  travelFee       Decimal?      @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())

  @@unique([workerProfileId, cityId, neighborhoodId])
  @@index([cityId, neighborhoodId])
}

model PortfolioImage {
  id              String              @id @default(cuid())
  workerProfileId String
  workerProfile   WorkerProfile       @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  title           String
  description     String?             @db.Text
  imageUrl        String
  altText         String?
  sortOrder       Int                 @default(0)
  isCover         Boolean             @default(false)
  status          ReviewStatus        @default(PENDING)
  moderatedAt     DateTime?
  moderationNotes String?
  cityId          String?
  evidenceType    WorkerEvidenceType?
  verifiedAt      DateTime?
  workerVisible   Boolean             @default(false)
  isVerifiedProof Boolean             @default(false)
  completedAt     DateTime?
  reports         ModerationReport[]
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([workerProfileId, status, sortOrder])
  @@index([isVerifiedProof, workerVisible])
  @@index([deletedAt])
}

model WorkerEvidence {
  id              String               @id @default(cuid())
  workerProfileId String
  workerProfile   WorkerProfile        @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  consentRecordId String?
  consentRecord   ConsentRecord?       @relation(fields: [consentRecordId], references: [id], onDelete: SetNull)
  type            WorkerEvidenceType
  status          WorkerEvidenceStatus @default(PENDING)
  title           String
  description     String?              @db.Text
  fileUrl         String?
  storageKey      String?
  categoryContext String?
  workerVisible   Boolean              @default(false)
  isPublicProof   Boolean              @default(false)
  metadata        Json?
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNotes     String?              @db.Text
  approvedAt      DateTime?
  rejectedAt      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([workerProfileId, type, status])
  @@index([consentRecordId])
  @@index([deletedAt])
}

model WorkerQualification {
  id                    String                  @id @default(cuid())
  workerProfileId       String
  workerProfile         WorkerProfile           @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  type                  WorkerQualificationType
  status                TrustVerificationStatus @default(PENDING)
  title                 String
  institution           String?
  educationLevel        String?
  issuer                String?
  completionYear        Int?
  registrationNumber    String?
  certificateFileUrl    String?
  certificateStorageKey String?
  notes                 String?                 @db.Text
  reviewedById          String?
  reviewedAt            DateTime?
  reviewNotes           String?                 @db.Text
  verifiedAt            DateTime?
  rejectedAt            DateTime?
  deletedAt             DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([workerProfileId, type, status])
  @@index([deletedAt])
}

model QuoteRequest {
  id              String             @id @default(cuid())
  code            String             @unique
  clientProfileId String
  clientProfile   ClientProfile      @relation(fields: [clientProfileId], references: [id], onDelete: Restrict)
  workerProfileId String
  workerProfile   WorkerProfile      @relation(fields: [workerProfileId], references: [id], onDelete: Restrict)
  serviceId       String?
  service         Service?           @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  cityId          String?
  city            City?              @relation(fields: [cityId], references: [id], onDelete: SetNull)
  neighborhoodId  String?
  neighborhood    Neighborhood?      @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  title           String
  description     String             @db.Text
  preferredDate   DateTime?
  budgetMin       Decimal?           @db.Decimal(10, 2)
  budgetMax       Decimal?           @db.Decimal(10, 2)
  platformEstimateMin Decimal?       @db.Decimal(10, 2)
  platformEstimateMax Decimal?       @db.Decimal(10, 2)
  platformFeePercent  Decimal?       @db.Decimal(5, 2)
  platformFeeAmount   Decimal?       @db.Decimal(10, 2)
  professionalNetMin  Decimal?       @db.Decimal(10, 2)
  professionalNetMax  Decimal?       @db.Decimal(10, 2)
  quotedAmount    Decimal?           @db.Decimal(10, 2)
  status          QuoteStatus        @default(OPEN)
  priority        QuotePriority      @default(NORMAL)
  expiresAt       DateTime?
  acceptedAt      DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  clientAvailabilityStatus ClientAvailabilityStatus @default(NOT_INFORMED)
  availabilityNote         String?                  @db.VarChar(200)
  lastAvailabilityUpdate   DateTime?
  messages        QuoteMessage[]
  review          Review?
  reports         ModerationReport[]
  contactRequests ContactRequest[]
  deletedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([clientProfileId, status])
  @@index([workerProfileId, status])
  @@index([serviceId, cityId, neighborhoodId])
  @@index([createdAt])
  @@index([deletedAt])
}

model QuoteMessage {
  id             String       @id @default(cuid())
  quoteRequestId String
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("QuoteMessageSender", fields: [senderId], references: [id], onDelete: Restrict)
  body           String       @db.Text
  attachmentUrl  String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([quoteRequestId, createdAt])
  @@index([senderId])
}

model Review {
  id              String             @id @default(cuid())
  workerProfileId String
  workerProfile   WorkerProfile      @relation(fields: [workerProfileId], references: [id], onDelete: Restrict)
  clientProfileId String?
  clientProfile   ClientProfile?     @relation(fields: [clientProfileId], references: [id], onDelete: SetNull)
  quoteRequestId  String?            @unique
  quoteRequest    QuoteRequest?      @relation(fields: [quoteRequestId], references: [id], onDelete: SetNull)
  clienteNome     String?
  clienteEmail    String?
  mostrarNome     Boolean            @default(false)
  rating          Int
  title           String
  comment         String             @db.Text
  status          ReviewStatus       @default(PENDING)
  moderatedById   String?
  moderatedBy     User?              @relation("ReviewModerator", fields: [moderatedById], references: [id], onDelete: SetNull)
  moderatedAt     DateTime?
  moderationNotes String?
  reports         ModerationReport[]
  deletedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([workerProfileId, status])
  @@index([clientProfileId])
  @@index([rating])
  @@index([deletedAt])
}

model Favorite {
  clientProfileId String
  workerProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@id([clientProfileId, workerProfileId])
  @@index([workerProfileId])
}

model ContactRequest {
  id              String               @id @default(cuid())
  clientProfileId String?
  clientProfile   ClientProfile?       @relation(fields: [clientProfileId], references: [id], onDelete: SetNull)
  workerProfileId String
  workerProfile   WorkerProfile        @relation(fields: [workerProfileId], references: [id], onDelete: Restrict)
  serviceId       String?
  service         Service?             @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  quoteRequestId  String?
  quoteRequest    QuoteRequest?        @relation(fields: [quoteRequestId], references: [id], onDelete: SetNull)
  cityId          String?
  city            City?                @relation(fields: [cityId], references: [id], onDelete: SetNull)
  neighborhoodId  String?
  neighborhood    Neighborhood?        @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  channel         ContactChannel       @default(PLATFORM)
  status          ContactRequestStatus @default(NEW)
  name            String?
  email           String?
  phone           String?
  message         String?              @db.Text
  metadata        Json?
  viewedAt        DateTime?
  contactedAt     DateTime?
  convertedAt     DateTime?
  reports         ModerationReport[]
  deletedAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([workerProfileId, status])
  @@index([clientProfileId])
  @@index([channel, createdAt])
  @@index([deletedAt])
}

model Lead {
  id              String         @id @default(cuid())
  clientProfileId String?
  clientProfile   ClientProfile? @relation(fields: [clientProfileId], references: [id], onDelete: SetNull)
  workerProfileId String
  workerProfile   WorkerProfile  @relation(fields: [workerProfileId], references: [id], onDelete: Restrict)
  channel         ContactChannel @default(WHATSAPP)
  source          String
  city            String?
  neighborhood    String?
  referrer        String?
  userAgent       String?
  metadata        Json?
  createdAt       DateTime       @default(now())

  @@index([workerProfileId, createdAt])
  @@index([channel, createdAt])
  @@index([city, neighborhood])
}

model VerificationRequest {
  id              String             @id @default(cuid())
  workerProfileId String
  workerProfile   WorkerProfile      @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  status          VerificationStatus @default(PENDING)
  documentType    String
  documentUrl     String
  notes           String?            @db.Text
  reviewedById    String?
  reviewedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([workerProfileId, status])
  @@index([status, createdAt])
}

model ModerationReport {
  id               String               @id @default(cuid())
  targetType       ModerationTargetType
  reason           ModerationReason
  status           ModerationStatus     @default(OPEN)
  description      String?              @db.Text
  reporterId       String?
  reporter         User?                @relation("ModerationReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  assignedAdminId  String?
  assignedAdmin    User?                @relation("ModerationAssignee", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  targetUserId     String?
  targetUser       User?                @relation("ModerationTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  workerProfileId  String?
  workerProfile    WorkerProfile?       @relation(fields: [workerProfileId], references: [id], onDelete: SetNull)
  portfolioImageId String?
  portfolioImage   PortfolioImage?      @relation(fields: [portfolioImageId], references: [id], onDelete: SetNull)
  reviewId         String?
  review           Review?              @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  quoteRequestId   String?
  quoteRequest     QuoteRequest?        @relation(fields: [quoteRequestId], references: [id], onDelete: SetNull)
  contactRequestId String?
  contactRequest   ContactRequest?      @relation(fields: [contactRequestId], references: [id], onDelete: SetNull)
  resolutionNotes  String?              @db.Text
  resolvedAt       DateTime?
  deletedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([targetType, status])
  @@index([assignedAdminId, status])
  @@index([workerProfileId])
  @@index([reviewId])
  @@index([deletedAt])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  title      String
  body       String           @db.Text
  actionUrl  String?
  metadata   Json?
  readAt     DateTime?
  archivedAt DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId, readAt])
  @@index([type, createdAt])
}

model PlatformSetting {
  id          String           @id @default(cuid())
  key         String           @unique
  value       Json
  valueType   SettingValueType @default(STRING)
  description String?
  isPublic    Boolean          @default(false)
  updatedById String?
  updatedBy   User?            @relation("SettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([isPublic])
}

model AdminLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("AdminLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entity, entityId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
